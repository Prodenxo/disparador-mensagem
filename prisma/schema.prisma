generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  SUPER_ADMIN
}

enum SectorRole {
  SECTOR_ADMIN
  EMPLOYEE
}

enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

enum PrivateCampaignStatus {
  SCHEDULED
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  globalRole   GlobalRole?
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  sectorLinks          UserSector[]
  announcements        Announcement[]        @relation("CreatedBy")
  continuousCampaigns  ContinuousCampaign[]  @relation("CampaignCreatedBy")
  contacts             Contact[]             @relation("ContactCreatedBy")
  contactLists         ContactList[]         @relation("ContactListCreatedBy")
  privateCampaigns     PrivateCampaign[]     @relation("PrivateCampaignCreatedBy")
}

model Sector {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              UserSector[]
  announcements        Announcement[]
  continuousCampaigns  ContinuousCampaign[]
  contacts             Contact[]
  contactLists         ContactList[]
  privateCampaigns     PrivateCampaign[]
}

model UserSector {
  id                     String     @id @default(uuid())
  userId                 String
  sectorId               String
  role                   SectorRole
  canCreateAnnouncements Boolean    @default(false)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sector Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@unique([userId, sectorId])
}

model WhatsappGroup {
  id               String   @id @default(uuid())
  jid              String   @unique
  name             String
  participantCount Int      @default(0)
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  announcements        Announcement[]
  continuousCampaigns  ContinuousCampaign[]
}

model AnnouncementImage {
  id        String   @id @default(uuid())
  mime      String
  data      String   @db.LongText
  createdAt DateTime @default(now())

  announcements       Announcement[]
  continuousCampaigns ContinuousCampaign[]
  privateCampaigns    PrivateCampaign[]
}

model Announcement {
  id          String             @id @default(uuid())
  sectorId    String
  groupId     String
  message     String             @db.Text
  imagePath   String?
  imageId     String?
  mentionAll  Boolean            @default(true)
  scheduledAt DateTime
  status      AnnouncementStatus @default(SCHEDULED)
  seriesId    String?
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  sector    Sector             @relation(fields: [sectorId], references: [id])
  group     WhatsappGroup      @relation(fields: [groupId], references: [id])
  image     AnnouncementImage? @relation(fields: [imageId], references: [id])
  createdBy User               @relation("CreatedBy", fields: [createdById], references: [id])
  logs      DispatchLog[]

  @@index([seriesId])
}

model DispatchLog {
  id             String   @id @default(uuid())
  announcementId String
  status         String
  errorMessage   String?  @db.Text
  mentionCount   Int      @default(0)
  sentAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id    String @id @default("default")
  key   String @unique
  value String @db.Text
}

model ContinuousCampaign {
  id              String    @id @default(uuid())
  name            String
  sectorId        String
  groupId         String
  message         String    @db.Text
  imagePath       String?
  imageId         String?
  mentionAll      Boolean   @default(true)
  active          Boolean   @default(false)
  intervalMinutes Int
  lastSentAt      DateTime?
  nextSendAt      DateTime?
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sector    Sector             @relation(fields: [sectorId], references: [id])
  group     WhatsappGroup      @relation(fields: [groupId], references: [id])
  image     AnnouncementImage? @relation(fields: [imageId], references: [id])
  createdBy User               @relation("CampaignCreatedBy", fields: [createdById], references: [id])
  logs      CampaignDispatchLog[]

  @@index([active])
}

model CampaignDispatchLog {
  id             String   @id @default(uuid())
  campaignId     String
  status         String
  errorMessage   String?  @db.Text
  mentionCount   Int      @default(0)
  sentAt         DateTime @default(now())

  campaign ContinuousCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Contact {
  id          String   @id @default(uuid())
  sectorId    String
  name        String
  phone       String
  notes       String?  @db.Text
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sector       Sector               @relation(fields: [sectorId], references: [id])
  createdBy    User                 @relation("ContactCreatedBy", fields: [createdById], references: [id])
  listMembers  ContactListMember[]
  dispatchLogs PrivateDispatchLog[]

  @@unique([sectorId, phone])
  @@index([sectorId])
}

model ContactList {
  id          String   @id @default(uuid())
  sectorId    String
  name        String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sector    Sector              @relation(fields: [sectorId], references: [id])
  createdBy User                @relation("ContactListCreatedBy", fields: [createdById], references: [id])
  members   ContactListMember[]
  campaigns PrivateCampaign[]

  @@index([sectorId])
}

model ContactListMember {
  id        String   @id @default(uuid())
  listId    String
  contactId String
  addedAt   DateTime @default(now())

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
}

model PrivateCampaign {
  id              String                @id @default(uuid())
  name            String
  sectorId        String
  listId          String
  message         String                @db.Text
  imagePath       String?
  imageId         String?
  scheduledAt     DateTime
  intervalSeconds Int                   @default(45)
  status          PrivateCampaignStatus @default(SCHEDULED)
  createdById     String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  sector    Sector             @relation(fields: [sectorId], references: [id])
  list      ContactList        @relation(fields: [listId], references: [id])
  image     AnnouncementImage? @relation(fields: [imageId], references: [id])
  createdBy User               @relation("PrivateCampaignCreatedBy", fields: [createdById], references: [id])
  logs      PrivateDispatchLog[]

  @@index([status, scheduledAt])
}

model PrivateDispatchLog {
  id           String   @id @default(uuid())
  campaignId   String
  contactId    String
  status       String
  errorMessage String?  @db.Text
  sentAt       DateTime @default(now())

  campaign PrivateCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
}
