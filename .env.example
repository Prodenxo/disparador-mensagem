# App
NODE_ENV=production
PORT=3000
APP_URL=http://localhost:3000
TZ=America/Sao_Paulo

# Database (MySQL)
# Local (npm run dev): localhost | Docker/Easypanel: mysql
DATABASE_URL=mysql://disparador:senha@localhost:3306/disparador
MYSQL_ROOT_PASSWORD=root
MYSQL_PASSWORD=senha

# Redis (BullMQ)
# Sem senha: redis://redisdisparador:6379
# Com senha: redis://:SUA_SENHA@redisdisparador:6379
REDIS_URL=redis://localhost:6379

# Auth (gerar com: openssl rand -base64 32)
AUTH_SECRET=troque-por-um-segredo-forte

# Super Admin inicial (seed)
SEED_SUPER_ADMIN_EMAIL=admin@empresa.com
SEED_SUPER_ADMIN_PASSWORD=troque-na-primeira-execucao
SEED_SUPER_ADMIN_NAME=Super Admin

# Evolution API (mesma instância do robozap — só envio, não alterar webhook)
EVOLUTION_API_URL=https://sua-evolution.com
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE_NAME=filhote

# Uploads (produção: /app/uploads com volume compartilhado web + worker)
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE_MB=16

# Worker — mesmo AUTH_SECRET do web; APP_URL interno do serviço web no Easypanel
# APP_URL=http://disparadordemensagem:3000
