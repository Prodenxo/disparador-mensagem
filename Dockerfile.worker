FROM node:20-alpine
WORKDIR /app
COPY package.json package-lock.json* ./
COPY prisma ./prisma
RUN npm ci || npm install
COPY . .
RUN npx prisma generate \
  && sed -i 's/\r$//' ./scripts/docker-entrypoint-worker.sh \
  && chmod +x ./scripts/docker-entrypoint-worker.sh
CMD ["./scripts/docker-entrypoint-worker.sh"]
